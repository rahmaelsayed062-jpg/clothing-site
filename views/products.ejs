<div class="products">
    <% products.forEach(product => { %>
        <a href = "/products/<%= product.slug %>"> 
            <div class="product-card">
                <div class="img-wrapper">
                    <img class = "main-img" src="<%= product.images[0] %>" alt="product-img">
                    <img class = "hover-img" src="<%= product.images[1] %>" alt="product-img">
                </div>
                <h3> <%= product.name %> </h3>
                <p class="price"> $<%= product.price %> </p>
            </div>
        </a>
    <% }); %>
</div>